<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Cargar Notas</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
<div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-4xl my-8">

    <h1 class="text-3xl font-bold text-center text-gray-800 mb-2">Cargar Notas</h1>
    <p class="text-center text-gray-500 mb-6">Materia: <span class="font-semibold">{{materia.nombre}}</span></p>

    {{#message}}
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-6">{{message}}</div>
    {{/message}}
    {{#error}}
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">{{error}}</div>
    {{/error}}

    <div class="overflow-x-auto border border-gray-200 rounded-md">
        <table class="w-full text-left bg-white">
            <thead>
            <tr class="bg-gray-100 text-gray-700 text-sm">
                <th class="p-3 border-b">Alumno</th>
                <th class="p-3 border-b">DNI</th>
                <th class="p-3 border-b">Estado</th>
                <th class="p-3 border-b">Nota</th>
                <th class="p-3 border-b text-center">Accion</th>
            </tr>
            </thead>
            <tbody class="text-sm">
            {{#estudiantes}}
            <tr class="border-b hover:bg-gray-50">
                <td class="p-3">{{nombre}} {{apellido}}</td>
                <td class="p-3">{{dni}}</td>
                <td class="p-3">{{estado}}</td>
                <td class="p-3">{{nota}}</td>
                <td class="p-3">
                    <form action="/cargarNotas" method="POST" class="flex gap-2 items-center justify-center">
                        <input type="hidden" name="estudiante_id" value="{{estudiante_id}}">
                        <input type="hidden" name="materia_id" value="{{materia_codigo}}">
                        <input type="number" name="nota" min="1" max="10" placeholder="1-10"
                               class="w-20 px-2 py-1 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <button type="submit"
                                class="bg-blue-600 text-white py-1 px-3 rounded hover:bg-blue-700">
                            Guardar
                        </button>
                        <button type="submit" name="estado_manual" value="aprobada"
                                class="bg-green-600 text-white py-1 px-3 rounded hover:bg-green-700">
                            Aprobada
                        </button>
                    </form>
                </td>
            </tr>
            {{/estudiantes}}
            {{^estudiantes}}
            <tr>
                <td colspan="5" class="p-6 text-center text-gray-500 italic">
                    No hay estudiantes inscriptos en esta materia.
                </td>
            </tr>
            {{/estudiantes}}
            </tbody>
        </table>
    </div>

    <div class="flex flex-col gap-2 mt-6">
        <button type="button" onclick="window.location.href='/materiasAsignadas'"
                class="w-full bg-gray-300 text-gray-800 py-2 px-4 rounded-md hover:bg-gray-400">
            Volver
        </button>
        <div class="text-center mt-2">
            <a href="/logout" class="text-red-600 hover:underline text-sm font-medium">Cerrar Sesion</a>
        </div>
    </div>

</div>
</body>
</html>