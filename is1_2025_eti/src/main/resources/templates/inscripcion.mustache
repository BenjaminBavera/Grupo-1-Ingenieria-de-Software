<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Inscripción a Materias</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">

<div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-4xl my-8">
    <h1 class="text-3xl font-bold text-center text-gray-800 mb-8">Módulo de Inscripción de Alumnos</h1>

    {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-6" role="alert">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
    {{/successMessage}}

    {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-6" role="alert">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
    {{/errorMessage}}

    <div class="bg-blue-50 p-6 rounded-md border border-blue-200 mb-8">
        <h2 class="text-xl font-semibold text-blue-900 mb-4 border-b border-blue-200 pb-2">Mis Datos</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
            <p><span class="font-semibold text-gray-700">Alumno:</span> {{usuario.nombre}} {{usuario.apellido}}</p>
            <p><span class="font-semibold text-gray-700">DNI:</span> {{usuario.dni}}</p>
            <p><span class="font-semibold text-gray-700">Plan de Estudios:</span> {{plan.nombre}}</p>
            <p><span class="font-semibold text-gray-700">Año de Plan:</span> {{plan.anio}}</p>
        </div>
    </div>

    <h2 class="text-xl font-semibold text-gray-800 mb-4 border-b pb-2">Materias Disponibles para Inscripción (Periodo Actual)</h2>
    <div class="overflow-x-auto mb-8 border border-gray-200 rounded-md">
        <table class="w-full text-left border-collapse bg-white">
            <thead>
            <tr class="bg-gray-100 text-gray-700 text-sm">
                <th class="p-3 border-b border-gray-300">Código</th>
                <th class="p-3 border-b border-gray-300">Nombre de la Materia</th>
                <th class="p-3 border-b border-gray-300 text-center">Acción</th>
            </tr>
            </thead>
            <tbody class="text-sm">
            {{#materiasInscribir}}
                <tr class="hover:bg-blue-50 transition border-b border-gray-100">
                    <td class="p-3 font-mono text-blue-800">{{codigo}}</td>
                    <td class="p-3">{{nombre}}</td>
                    <td class="p-3 text-center">
                        <form action="/inscribir" method="POST" class="m-0">
                            <input type="hidden" name="materia_id" value="{{id}}">
                            <input type="hidden" name="plan_id" value="{{plan.id}}">
                            <button type="submit" class="bg-blue-600 text-white font-semibold py-1 px-4 rounded hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-150">
                                Inscribirse
                            </button>
                        </form>
                    </td>
                </tr>
            {{/materiasInscribir}}
            {{^materiasInscribir}}
                <tr>
                    <td colspan="3" class="p-6 text-center text-gray-500 italic">
                        No hay materias disponibles para inscripción que cumplan con las correlatividades y pertenezcan a tu plan.
                    </td>
                </tr>
            {{/materiasInscribir}}
            </tbody>
        </table>
    </div>

    <h2 class="text-xl font-semibold text-gray-800 mb-4 border-b pb-2">Mis Inscripciones Actuales</h2>
    <div class="overflow-x-auto mb-8 border border-gray-200 rounded-md">
        <table class="w-full text-left border-collapse bg-white">
            <thead>
            <tr class="bg-gray-100 text-gray-700 text-sm">
                <th class="p-3 border-b border-gray-300">Código</th>
                <th class="p-3 border-b border-gray-300">Nombre de la Materia</th>
                <th class="p-3 border-b border-gray-300">Año / Periodo</th>
            </tr>
            </thead>
            <tbody class="text-sm">
            {{#materiasMatriculadas}}
                <tr class="hover:bg-green-50 transition border-b border-gray-100">
                    <td class="p-3 font-mono text-green-800">{{codigo}}</td>
                    <td class="p-3">{{nombre}}</td>
                    <td class="p-3 text-gray-600">Periodo Actual</td>
                </tr>
            {{/materiasMatriculadas}}
            {{^materiasMatriculadas}}
                <tr>
                    <td colspan="3" class="p-6 text-center text-gray-500 italic">
                        No estás inscrito en ninguna materia todavía.
                    </td>
                </tr>
            {{/materiasMatriculadas}}
            </tbody>
        </table>
    </div>

    <div class="flex flex-col gap-2 mt-6">
        <button type="button" onclick="window.location.href='/dashboardEstudiante'"
                class="w-full bg-gray-300 text-gray-800 py-2 px-4 rounded-md hover:bg-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2">
            Volver
        </button>
        <div class="text-center mt-2">
            <a href="/logout" class="text-red-600 hover:underline text-sm font-medium">Cerrar Sesión</a>
        </div>
    </div>

</div>

</body>
</html>