<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Mis Materias Asignadas</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">

<div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-4xl my-8">
    <h1 class="text-3xl font-bold text-center text-blue-900 mb-8">Mis Materias Asignadas</h1>

    {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-6" role="alert">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
    {{/errorMessage}}

    <div class="bg-white border border-gray-200 rounded-md shadow-sm overflow-hidden mb-8">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                <tr class="bg-teal-50 text-teal-900 text-sm border-b border-gray-200">
                    <th class="p-4 font-semibold">Código</th>
                    <th class="p-4 font-semibold">Nombre de la Materia</th>
                    <th class="p-4 font-semibold">Mi Cargo</th>
                    <th class="p-4 font-semibold">Plan de Estudio</th>
                </tr>
                </thead>
                <tbody class="text-sm text-gray-700">
                {{#materiasAsignadas}}
                    <tr class="hover:bg-gray-50 transition border-b border-gray-100">
                        <td class="p-4 font-mono text-gray-600">{{id}}</td>
                        <td class="p-4 font-medium">{{materia_nombre}}</td>
                        <td class="p-4"><span class="bg-blue-100 text-blue-800 py-1 px-2 rounded text-xs font-semibold">{{cargo}}</span></td>
                        <td class="p-4">
                            {{#plan_anio}}Año {{plan_anio}}{{/plan_anio}}
                            {{^plan_anio}}<span class="text-gray-400 italic">Sin plan asignado</span>{{/plan_anio}}
                        </td>
                    </tr>
                {{/materiasAsignadas}}

                {{^materiasAsignadas}}
                    <tr>
                        <td colspan="4" class="p-8 text-center text-gray-500 italic">
                            Aún no tenés materias asignadas a tu cargo.
                        </td>
                    </tr>
                {{/materiasAsignadas}}
                </tbody>
            </table>
        </div>
    </div>

    <div class="flex justify-center mt-6">
        <button type="button" onclick="window.location.href='/dashboardProfesor'"
                class="bg-gray-200 text-gray-800 font-semibold py-2 px-8 rounded-md hover:bg-gray-300 focus:outline-none focus:ring-2 focus:ring-gray-400 transition-colors">
            Volver a mi Portal
        </button>
    </div>
</div>

</body>
</html>