<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Gestión de Planes</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">

<div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-md my-8">
    <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Crear Plan de Estudio</h1>

    {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
    {{/successMessage}}

    {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
    {{/errorMessage}}

    <div class="bg-gray-50 p-4 rounded-md border border-gray-200 mb-6">
        <form action="/crearPlan" method="post" class="space-y-4">
            <div>
                <label for="anio" class="block text-gray-700 text-sm font-medium mb-1">Año del Plan:</label>
                <input type="number" id="anio" name="anio" required placeholder="Ej: 2024"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>

            <div>
                <label for="carrera_id" class="block text-gray-700 text-sm font-medium mb-1">ID de la Carrera:</label>
                <input type="number" id="carrera_id" name="carrera_id" required placeholder="Ej: 1"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                <p class="text-xs text-gray-500 mt-1">Ingresá el número identificador de la carrera.</p>
            </div>

            <button type="submit"
                    class="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 font-semibold mt-4">
                Guardar Plan
            </button>
        </form>
    </div>

    <button type="button" onclick="window.location.href='/dashboard'"
            class="w-full bg-gray-300 text-gray-800 py-2 px-4 rounded-md hover:bg-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 transition">
        Volver al Panel Principal
    </button>
</div>

</body>
</html>