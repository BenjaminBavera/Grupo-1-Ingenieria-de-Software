<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Gestión de Materias</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">

<div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-3xl my-8">
    <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Gestión de Materias</h1>

    {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
    {{/successMessage}}

    {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
    {{/errorMessage}}

    <div class="bg-gray-50 p-4 rounded-md border border-gray-200 mb-8">
        <h2 class="text-xl font-semibold text-gray-800 mb-4 border-b pb-2">Crear Nueva Materia</h2>
        <form action="/crearMateria" method="post" class="space-y-4">
            <div>
                <label for="nombre" class="block text-gray-700 text-sm font-medium mb-1">Nombre de la Materia:</label>
                <input type="text" id="nombre" name="nombre" required placeholder="Ej: Algoritmos I"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="codigo" class="block text-gray-700 text-sm font-medium mb-1">Código:</label>
                <input type="number" id="codigo" name="codigo" required placeholder="Ej: 101"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <button type="submit"
                    class="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                Guardar Materia
            </button>
        </form>
    </div>

    <div class="bg-gray-50 p-4 rounded-md border border-gray-200 mb-8">
        <h2 class="text-xl font-semibold text-gray-800 mb-4 border-b pb-2">Vincular Materia a un Plan</h2>
        <form action="/vincularPlanMateria" method="post" class="space-y-4">
            <div>
                <label for="plan_id" class="block text-gray-700 text-sm font-medium mb-1">Seleccionar Plan:</label>
                <select id="plan_id" name="plan_id" required
                        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                    <option value="" disabled selected>-- Seleccione un Plan --</option>
                    {{#planes}}
                        <option value="{{id}}">{{nombre}}</option>
                    {{/planes}}
                </select>
            </div>
            <div>
                <label for="materia_id" class="block text-gray-700 text-sm font-medium mb-1">Seleccionar Materia:</label>
                <select id="materia_id" name="materia_id" required
                        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                    <option value="" disabled selected>-- Seleccione una Materia --</option>
                    {{#materias}}
                        <option value="{{id}}">{{nombre}} ({{codigo}})</option>
                    {{/materias}}
                </select>
            </div>
            <button type="submit"
                    class="w-full bg-teal-600 text-white py-2 px-4 rounded-md hover:bg-teal-700 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:ring-offset-2">
                Vincular al Plan
            </button>
        </form>
    </div>

    <h2 class="text-xl font-semibold text-gray-800 mb-4 border-b pb-2">Lista General de Materias</h2>
    <div class="overflow-x-auto mb-6">
        <table class="w-full text-left border-collapse">
            <thead>
            <tr class="bg-gray-200 text-gray-700 text-sm">
                <th class="p-3 border-b border-gray-300 rounded-tl-md">ID</th>
                <th class="p-3 border-b border-gray-300">Código</th>
                <th class="p-3 border-b border-gray-300">Nombre</th>
                <th class="p-3 border-b border-gray-300 text-center rounded-tr-md">Acción</th>
            </tr>
            </thead>
            <tbody class="text-sm">
            {{#materias}}
                <tr class="hover:bg-gray-100 border-b border-gray-200">
                    <td class="p-3">{{id}}</td>
                    <td class="p-3 font-mono text-gray-600">{{codigo}}</td>
                    <td class="p-3">{{nombre}}</td>
                    <td class="p-3 text-center">
                        <form action="/eliminarMateria" method="POST" class="inline">
                            <input type="hidden" name="materia_id" value="{{id}}">
                            <button type="submit" class="text-red-600 hover:text-red-800 font-medium transition"
                                    onclick="return confirm('¿Está seguro de eliminar esta materia?')">
                                Eliminar
                            </button>
                        </form>
                    </td>
                </tr>
            {{/materias}}
            {{^materias}}
                <tr>
                    <td colspan="4" class="p-4 text-center text-gray-500">No hay materias cargadas.</td>
                </tr>
            {{/materias}}
            </tbody>
        </table>
    </div>

    <button type="button" onclick="window.location.href='/dashboard'"
            class="w-full bg-gray-300 text-gray-800 py-2 px-4 rounded-md hover:bg-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 mt-2">
        Volver al Dashboard
    </button>
    <div class="text-center mt-4">
        <a href="/" class="text-blue-600 hover:underline text-sm">Cerrar Sesión</a>
    </div>

</div>
</body>
</html>