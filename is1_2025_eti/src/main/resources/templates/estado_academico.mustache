<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Estado Académico</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">

<div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-4xl my-8">

    <h1 class="text-3xl font-bold text-center text-gray-800 mb-8">
        Mi Estado Académico
    </h1>

    {{#message}}
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-6">
        {{message}}
    </div>
    {{/message}}

    {{#error}}
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6">
        {{error}}
    </div>
    {{/error}}

    <!-- DATOS DEL ESTUDIANTE -->
    <div class="bg-blue-50 p-6 rounded-md border border-blue-200 mb-8">
        <h2 class="text-xl font-semibold text-blue-900 mb-4 border-b pb-2">
            Mis Datos
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
            <p><b>Alumno:</b> {{usuario.nombre}} {{usuario.apellido}}</p>
            <p><b>DNI:</b> {{usuario.dni}}</p>
        </div>
    </div>

    <!-- TABLA -->
    <h2 class="text-xl font-semibold text-gray-800 mb-4 border-b pb-2">
        Mis Materias
    </h2>

    <div class="overflow-x-auto border rounded-md">
        <table class="w-full text-left bg-white">
            <thead>
                <tr class="bg-gray-100 text-gray-700 text-sm">
                    <th class="p-3 border-b">Código</th>
                    <th class="p-3 border-b">Materia</th>
                    <th class="p-3 border-b">Estado</th>
                </tr>
            </thead>

            <tbody class="text-sm">
                {{#materias}}
                <tr class="hover:bg-gray-50 border-b">
                    <td class="p-3 font-mono">{{materia_codigo}}</td>
                    <td class="p-3">{{nombre}}</td>
                    <td class="p-3">
                        <span class="px-2 py-1 rounded text-white
                            {{#estado}}bg-green-500{{/estado}}">
                            {{estado}}
                        </span>
                    </td>
                </tr>
                {{/materias}}

                {{^materias}}
                <tr>
                    <td colspan="3" class="p-6 text-center text-gray-500 italic">
                        No tenés materias registradas.
                    </td>
                </tr>
                {{/materias}}
            </tbody>
        </table>
    </div>

    <!-- BOTONES -->
    <div class="flex flex-col gap-2 mt-6">
        <button onclick="window.location.href='/dashboardEstudiante'"
            class="w-full bg-gray-300 py-2 rounded hover:bg-gray-400">
            Volver
        </button>

        <a href="/logout" class="text-center text-red-600 hover:underline">
            Cerrar Sesión
        </a>
    </div>

</div>
</body>
</html>