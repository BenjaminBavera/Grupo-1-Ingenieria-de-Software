<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Bienvenido</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
<div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-4xl">
    <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Panel de Control</h1>

    {{#username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Bienvenido/a, <span class="font-semibold text-blue-600">{{username}}</span>!</p>
    {{/username}}
    {{^username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Bienvenido/a!</p>
    {{/username}}

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-yellow-50 border border-yellow-200 p-6 rounded-lg text-center shadow-sm">
            <h2 class="text-2xl font-bold text-yellow-700 mb-3">Gestión de Administradores</h2>
            <p class="text-gray-600 mb-4">Crea Administradores. </p>
            <a href="/crearAdmin" class="inline-block bg-yellow-600 text-white py-2 px-4 rounded-md hover:bg-yellow-700 transition duration-300">Gestionar administradores</a>
        </div>
        <div class="bg-indigo-50 border border-indigo-200 p-6 rounded-lg text-center shadow-sm">
            <h2 class="text-2xl font-bold text-indigo-700 mb-3">Gestión de Profesores</h2>
            <p class="text-gray-600 mb-4">Crea Profesores. </p>
            <a href="/registrarProfesor" class="inline-block bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition duration-300">Gestionar profesores</a>
        </div>
        <div class="bg-teal-50 border border-teal-200 p-6 rounded-lg text-center shadow-sm">
            <h2 class="text-2xl font-bold text-teal-700 mb-3">Gestión de Estudiantes</h2>
            <p class="text-gray-600 mb-4">Crea Estudiantes.</p>
            <a href="/registrarEstudiante" class="inline-block bg-teal-600 text-white py-2 px-4 rounded-md hover:bg-teal-700 transition duration-300">Gestionar estudiantes</a>
        </div>
    </div>
    <button type="button" onclick="window.location.href='/dashboard'"
            class="w-full bg-gray-300 text-gray-800 py-2 px-4 rounded-md hover:bg-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 mt-2">
        Volver al Dashboard
    </button>
</div>
</body>
</html>