<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal del Profesor</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
<div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-4xl">
    <h1 class="text-3xl font-bold text-center text-blue-900 mb-6">Portal del Profesor</h1>

    {{#username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Hola, <span class="font-semibold text-blue-600">{{username}}</span>!</p>
    {{/username}}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-teal-50 border border-teal-200 p-6 rounded-lg text-center shadow-sm hover:shadow-md transition">
            <h2 class="text-2xl font-bold text-teal-800 mb-3">Materias Asignadas</h2>
            <p class="text-gray-600 mb-4">Mira las materias que tienes asignadas.</p>
            <a href="/materiasAsignadas" class="inline-block bg-teal-600 text-white py-2 px-6 rounded-md hover:bg-teal-700 transition duration-300 font-semibold">
                Mirar materias asignadas
            </a>
        </div>

        <div class="bg-teal-50 border border-teal-200 p-6 rounded-lg text-center shadow-sm hover:shadow-md transition">
            <h2 class="text-2xl font-bold text-purple-800 mb-3">Mi Perfil</h2>
            <p class="text-gray-600 mb-4">Gestioná tus datos y contraseña.</p>
            <a href="/perfilProfesor" class="inline-block bg-purple-600 text-white py-2 px-6 rounded-md hover:bg-purple-700 transition duration-300 font-semibold">
            Ir a Perfil
            </a>
        </div>
</div>

<div class="w-full flex justify-center mt-6 border-t pt-6">
    <a href="/logout" class="bg-red-600 text-white py-2 px-8 rounded-md hover:bg-red-700 transition duration-300 text-lg font-medium">
        Cerrar Sesión
    </a>
</div>
</body>
</html>