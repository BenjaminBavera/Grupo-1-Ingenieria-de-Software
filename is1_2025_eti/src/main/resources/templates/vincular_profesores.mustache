<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Vincular Profesores</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">

<div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-3xl my-8">
    <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Vincular Profesores</h1>

    {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
    {{/successMessage}}

    {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
    {{/errorMessage}}

    <div class="bg-gray-50 p-4 rounded-md border border-gray-200 mb-8">
        <h2 class="text-xl font-semibold text-gray-800 mb-4 border-b pb-2">Vincular Materia a Profesor</h2>
        <form action="/vincularProfesores" method="post" class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="profesor_id" class="block text-gray-700 text-sm font-medium mb-1">Asignar al Profesor:</label>
                    <select id="profesor_id" name="profesor_id" required
                            class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white">
                        <option value="" disabled selected>-- Seleccione un Profesor--</option>
                        {{#profesores}}
                            <option value="{{id}}">{{nombre}} ({{apellido}})</option>
                        {{/profesores}}
                    </select>
                </div>
            <div>
                <label for="materia_id" class="block text-gray-700 text-sm font-medium mb-1">Materia:</label>
                <select id="materia_id" name="materia_id" required
                        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white">
                    <option value="" disabled selected>-- Seleccione una Materia:--</option>
                    {{#materias}}
                        <option value="{{id}}">{{nombre}} ({{codigo}})</option>
                    {{/materias}}
                </select>
            </div>
            </div>
            <div>
                <label for="cargo" class="block text-gray-700 text-sm font-medium mb-1">Cargo:</label>
                <select id="cargo" name="cargo" required
                        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-teal-500 bg-white">
                    <option value="" disabled selected>-- Seleccione un Cargo:--</option>
                    <option value="Responsable de Cátedra"> Responsable de Cátedra</option>
                    <option value="Jefe Trabajos Prácticos"> Jefe Trabajos Prácticos</option>
                    <option value="Ayudante"> Ayudante</option>
                </select>
            </div>
            <button type="submit"
                    class="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                Guardar vinculación
            </button>
        </form>
    </div>

    <button type="button" onclick="window.location.href='/dashboard'"
            class="w-full bg-gray-300 text-gray-800 py-2 px-4 rounded-md hover:bg-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 mt-2">
        Volver al Dashboard
    </button>
    <div class="text-center mt-4">
        <a href="/" class="text-blue-600 hover:underline text-sm">Cerrar Sesión</a>
    </div>

</div>
</body>
</html>