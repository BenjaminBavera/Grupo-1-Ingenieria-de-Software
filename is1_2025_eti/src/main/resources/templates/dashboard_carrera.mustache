<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Bienvenido</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
<div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-4xl">
    <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Panel de Control</h1>

    {{#username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Bienvenido/a, <span class="font-semibold text-blue-600">{{username}}</span>!</p>
    {{/username}}
    {{^username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Bienvenido/a!</p>
    {{/username}}

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-yellow-50 border border-yellow-200 p-6 rounded-lg text-center shadow-sm">
            <h2 class="text-2xl font-bold text-yellow-700 mb-3">Gestión de Carreras</h2>
            <p class="text-gray-600 mb-4">Crea carreras</p>
            <a href="/crearCarrera" class="inline-block bg-yellow-600 text-white py-2 px-4 rounded-md hover:bg-yellow-700 transition duration-300">Gestionar carrera</a>
        </div>
        <div class="bg-indigo-50 border border-indigo-200 p-6 rounded-lg text-center shadow-sm">
            <h2 class="text-2xl font-bold text-indigo-700 mb-3">Gestión de Materias</h2>
            <p class="text-gray-600 mb-4">Crea materias y asígnalas a los planes vigentes</p>
            <a href="/crearMateria" class="inline-block bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition duration-300">Gestionar materias</a>
        </div>
        <div class="bg-teal-50 border border-teal-200 p-6 rounded-lg text-center shadow-sm">
            <h2 class="text-2xl font-bold text-teal-700 mb-3">Gestión de Planes</h2>
            <p class="text-gray-600 mb-4">Crea planes de estudio y asígnalas a las carreras.</p>
            <a href="/crearPlan" class="inline-block bg-teal-600 text-white py-2 px-4 rounded-md hover:bg-teal-700 transition duration-300">Gestionar planes</a>
        </div>
    </div>
    <div class="w-full flex justify-center mt-6">
        <a href="/logout"
           class="bg-red-600 text-white py-2 px-6 rounded-md hover:bg-red-700 transition duration-300 text-lg">
            Cerrar Sesión
        </a>
    </div>
</div>
</body>
</html>